# Database 
DATABASE_URL=postgresql://<your_system_user>@localhost:5432/cami_project

# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=your_secret_key_here

# Get a free key at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# Set to false when running locally over HTTP; defaults to true (required for HTTPS in production)
COOKIE_SECURE=false
